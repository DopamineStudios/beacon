{
  "branches": ["main"],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits",
        "presetConfig": {
          "types": [
            { "type": "feat", "section": "Features & Minor Updates and Changes", "hidden": false },
            { "type": "fix", "section": "Bug Fixes", "hidden": false },
            { "type": "style", "section": "Styling, UI, Code Cleanup, and Linting Fixes", "hidden": false },
            { "type": "docs", "section": "Documentation Changes", "hidden": false },
            { "type": "perf", "section": "Performance Improvements", "hidden": false },
            { "type": "refactor", "section": "Code Refactoring", "hidden": false }
          ],
          "compareUrlFormat": "{{host}}/{{owner}}/{{repository}}/compare/{{previousTag}}...{{currentTag}}"
        }
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "sed -i 's/version = \".*\"/version = \"${nextRelease.version}\"/' pyproject.toml && sed -i 's/framework_version = \".*\"/framework_version = \"${nextRelease.version}\"/' src/beacon/ext/path.py"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["pyproject.toml", "src/beacon/ext/path.py", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]"
      }
    ],
    "@semantic-release/github"
  ]
}